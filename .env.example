# ─────────────────────────────────────────────────────────────────────────────
# Smartsheet Claude Processor — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Your Smartsheet API access token
# Generate at: Smartsheet → Account → Personal Settings → API Access
SMARTSHEET_TOKEN=your_smartsheet_token_here

# Your Anthropic API key
# Generate at: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Comma-separated list of Smartsheet sheet IDs to watch
# Find sheet IDs in the Smartsheet URL or via the API
SHEET_IDS=5337282696400772,5267249496543108,901776017411972

# ── Optional ──────────────────────────────────────────────────────────────────

# Port to run the FastAPI server on (default: 8000)
PORT=8000

# Host to bind to (default: 0.0.0.0 — listens on all interfaces)
HOST=0.0.0.0

# Timeout in seconds for Anthropic API calls
# Claude + MCP + web search can take 60-120 seconds — don't set this too low
ANTHROPIC_TIMEOUT=180

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-20250514

# How often to poll sheets for rows that missed their webhook (minutes, default: 10)
# The poll only processes rows with human activity in the last 2x this interval,
# so Claude is never called for old untouched rows.
POLL_INTERVAL_MINS=10
